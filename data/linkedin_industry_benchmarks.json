  "posting_optimization_tips": {
    "title_optimization": {
      "impact": "high",
      "guidelines": [
        "Use standard job titles (Software Engineer > Ninja Developer) -- 30% more views",
        "Include seniority level (Senior, Lead, Director) -- 25% higher qualified applicants",
        "Avoid internal jargon -- 40% drop in views for non-standard titles",
        "Keep under 60 characters for full mobile visibility",
        "Include one keyword candidates search for"
      ]
    },
    "description_optimization": {
      "impact": "high",
      "guidelines": [
        "150-300 words ideal length -- 18% higher apply rate vs 500+ words",
        "Lead with impact and opportunity, not requirements",
        "Include salary range -- 75% more applications when listed",
        "Bullet points for requirements -- 12% higher readability score",
        "Include company culture and benefits in first 200 characters (mobile preview)"
      ]
    },
    "timing_optimization": {
      "impact": "medium",
      "guidelines": [
        "Post Tuesday-Thursday for highest visibility (15-20% more views than weekend)",
        "Morning posts (8-10 AM local) get 23% more first-day applications",
        "Refresh/repost every 7-10 days to reset algorithmic boost",
        "January and September are peak hiring months (20-30% more activity)",
        "Avoid posting during major holidays (50-70% drop in engagement)"
      ]
    },
    "application_method": {
      "impact": "very_high",
      "guidelines": [
        "Easy Apply increases applications by 2.3-3.5x vs ATS redirect",
        "Mobile candidates abandon 65% of ATS redirects",
        "Easy Apply completion rate: 92% vs ATS: 35%",
        "If ATS required, ensure mobile-optimized career site",
        "Consider Easy Apply for volume roles, ATS for senior/specialized roles"
      ]
    },
    "salary_transparency": {
      "impact": "high",
      "guidelines": [
        "Listings with salary get 75% more applications (LinkedIn data)",
        "Salary range acceptable (e.g., $80K-$100K) vs exact figure",
        "State salary band even if competitive -- shows transparency",
        "Include total compensation (base + bonus + equity) for tech roles",
        "Required by law in many US states (CO, NY, CA, WA, CT, MD)"
      ]
    }
  },

