  "metadata": {
    "title": "Healthcare Specialty Compensation 2026 - 40 Roles by Region and Metro",
    "description": "Median and 90th-percentile (P90) annual compensation for 40 healthcare roles, including RN, LPN, APRN, NP, PA, MD by specialty, pharmacist, PT, OT, SLP, RT, med tech, CNA, and allied health. Broken down by 4 US regions and top 20 metros. Every datapoint is grounded in public sources: BLS OES 2024, Medscape Physician Compensation 2024, Nurse.com 2024 salary report, AAMC data.",
    "last_updated": "2026-04-24",
    "version": "1.0",
    "data_period": "BLS OES May 2024 publication; Medscape survey fielded Jan-Apr 2024; Nurse.com 2024 annual report",
    "currency": "USD, annual (unless noted hourly)",
    "total_records": 1180,
    "roles_covered": 40,
    "regions_covered": 4,
    "metros_covered": 20,
    "sources": [
      {"id": "bls_oes_may2024", "name": "BLS Occupational Employment and Wage Statistics May 2024 (published April 2025)", "publisher": "U.S. Bureau of Labor Statistics", "url": "https://www.bls.gov/oes/", "detail": "Used for RN, LPN, CNA, PT, OT, SLP, RT, pharmacist, med tech, allied health, and general practitioner medians; BLS SOC codes referenced.", "tier": 1, "publication_year": 2025},
      {"id": "medscape_physician_comp_2024", "name": "Medscape Physician Compensation Report 2024", "publisher": "Medscape / WebMD", "url": "https://www.medscape.com/slideshow/2024-compensation-overview-6016898", "sample_size": "~10,000 US physicians across 29+ specialties", "tier": 1, "publication_year": 2024, "detail": "Primary source for per-specialty physician compensation; supplemented with Doximity Physician Report 2024."},
      {"id": "doximity_compensation_2024", "name": "Doximity Physician Compensation Report 2024", "publisher": "Doximity", "url": "https://press.doximity.com/articles/doximity-physician-compensation-report-2024", "sample_size": "33,000+ US physicians", "tier": 1, "publication_year": 2024},
