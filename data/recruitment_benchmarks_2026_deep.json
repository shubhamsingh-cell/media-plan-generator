    "version": "1.0",
    "data_period": "2024-01 through 2025-12 (rolling 24 months)",
    "geographic_scope": "United States",
    "currency": "USD",
    "total_records": 1850,
    "verticals_covered": 12,
    "metros_covered": 40,
    "channels_covered": 7,
