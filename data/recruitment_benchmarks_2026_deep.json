    ],
    "methodology_notes": [
      "CPC = Cost per click. Ranges reflect the 25th to 75th percentile of observed auctions for the given segment.",
      "CPA = Cost per application (long-form ATS unless flagged easy-apply). Driven by click-through rate and apply rate.",
      "CPH = Cost per hire. Blends sourcing, advertising, recruiter time, referral, and agency fees.",
      "Apply rate = completed applications / clicks on job ad.",
      "Time-to-fill = calendar days from requisition opened to offer accepted.",
      "COLI multiplier = C2ER Cost of Living Index / 100 (US average = 1.00).",
      "Metro multiplier = local CPC and CPA divergence vs national median, blending BLS wages + COLI + Appcast geo data.",
      "Values marked 'estimated' are triangulated from 2+ tier-2 sources when primary benchmark data is unavailable.",
      "All monetary values are USD."
    ],
    "units": {
      "cpc": "USD per click",
      "cpa": "USD per application",
      "cph": "USD per hire",
      "apply_rate": "decimal (0.10 = 10%)",
      "time_to_fill": "days"
    }
  },

